import akshare as ak
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.dates as mdates

# ================= 1. 数据获取模块 =================
def fetch_data(symbol="513180", period="1"):
    """拉取真实分钟线数据（使用前复权消除分红影响）"""
    print(f"正在拉取 {symbol} 的 {period}分钟级 真实交易数据...")
    df = ak.fund_etf_hist_min_em(symbol=symbol, period=period, adjust="qfq")
    df = df[['时间', '收盘']].rename(columns={'时间': 'datetime', '收盘': 'close'})
    df['datetime'] = pd.to_datetime(df['datetime'])
    return df.sort_values('datetime').reset_index(drop=True)

# ================= 2. 策略回测模块 =================
class T0GridBacktester:
    def __init__(self, df_prices, base_price, step_pct=0.04, total_funds=100000):
        self.df = df_prices
        self.base_price = base_price
        self.step_pct = step_pct
        
        # 资金划分为50%底仓，50%网格现金
        self.cash = total_funds / 2
        self.position = (total_funds / 2) / base_price
        self.grid_capital = self.cash / 5  # 假设向下分5档
        
        self.trades = []
        self.current_anchor = base_price 
        self.history_assets = []

    def run_backtest(self):
        print(f"--- 回测开始 | 基准价: {self.base_price:.3f} | 步长: {self.step_pct*100}% ---")
        for index, row in self.df.iterrows():
            current_price, timestamp = row['close'], row['datetime']
            price_change = (current_price - self.current_anchor) / self.current_anchor
            
            # 向下网格 (包含跳空穿透逻辑)
            if price_change <= -self.step_pct:
                penetrated_levels = int(abs(price_change) // self.step_pct)
                for _ in range(penetrated_levels):
                    if self.cash >= self.grid_capital:
                        buy_qty = self.grid_capital / current_price
                        self.position += buy_qty
                        self.cash -= self.grid_capital
                        self.trades.append({'time': timestamp, 'type': 'BUY', 'price': current_price})
                if penetrated_levels > 0: 
                    self.current_anchor = current_price  # 重置动态锚点
            
            # 向上网格 (包含跳空穿透逻辑)
            elif price_change >= self.step_pct:
                penetrated_levels = int(price_change // self.step_pct)
                for _ in range(penetrated_levels):
                    sell_qty = self.grid_capital / self.base_price
                    if self.position >= sell_qty:
                        self.position -= sell_qty
                        self.cash += sell_qty * current_price
                        self.trades.append({'time': timestamp, 'type': 'SELL', 'price': current_price})
                if penetrated_levels > 0: 
                    self.current_anchor = current_price  # 重置动态锚点
            
            # 记录每日总资产
            self.history_assets.append({
                'datetime': timestamp, 
                'total_asset': self.cash + self.position * current_price
            })
            
        return pd.DataFrame(self.history_assets), pd.DataFrame(self.trades)

# ================= 3. 数据可视化模块 =================
def plot_grid_results(df_prices, df_assets, df_trades):
    """绘制价格走势买卖点与资产收益对比图"""
    # 设置中文字体（确保Matplotlib能显示中文）
    plt.rcParams['font.sans-serif'] = ['SimHei', 'Arial Unicode MS']
    plt.rcParams['axes.unicode_minus'] = False 

    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10), gridspec_kw={'height_ratios': [2, 1]})
    
    # --- 图1：价格走势与买卖点 ---
    ax1.plot(df_prices['datetime'], df_prices['close'], label='ETF价格走势', color='#1f77b4', alpha=0.6)
    buys = df_trades[df_trades['type'] == 'BUY']
    sells = df_trades[df_trades['type'] == 'SELL']
    ax1.scatter(buys['time'], buys['price'], marker='^', color='red', s=60, label='买入 (Buy)', zorder=5)
    ax1.scatter(sells['time'], sells['price'], marker='v', color='green', s=60, label='卖出 (Sell)', zorder=5)
    
    ax1.set_title('ETF价格走势与网格买卖点自动化标注', fontsize=14)
    ax1.set_ylabel('价格 (元)')
    ax1.legend(loc='upper left')
    ax1.grid(True, linestyle='--', alpha=0.5)
    
    # --- 图2：资产收益对比 ---
    ax2.plot(df_assets['datetime'], df_assets['total_asset'], label='网格策略总资产', color='#ff7f0e', linewidth=2)
    
    # 计算全仓持有的基准收益曲线
    initial_funds = df_assets['total_asset'].iloc[0]
    initial_price = df_prices['close'].iloc[0]
    benchmark_assets = (initial_funds / initial_price) * df_prices['close']
    ax2.plot(df_prices['datetime'], benchmark_assets, label='全仓持有基准', color='gray', linestyle='-.', alpha=0.6)
    
    ax2.set_title('网格策略 vs 全仓持有 收益曲线对比', fontsize=14)
    ax2.set_ylabel('总资产 (元)')
    ax2.legend(loc='upper left')
    ax2.grid(True, linestyle='--', alpha=0.5)
    
    # 格式化X轴
    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%m-%d %H:%M'))
    ax2.xaxis.set_major_formatter(mdates.DateFormatter('%m-%d %H:%M'))
    fig.autofmt_xdate()
    
    plt.tight_layout()
    plt.show()

# ================= 4. 执行主程序 =================
if __name__ == "__main__":
    # 获取恒生科技ETF数据并截取最近一段震荡行情（例如最近3000分钟）
    df_real = fetch_data("513180", "1")
    if df_real is not None:
        df_test = df_real.tail(3000).copy()
        initial_price = df_test['close'].iloc[0]
        
        # 实例化并运行回测
        backtester = T0GridBacktester(df_prices=df_test, base_price=initial_price, step_pct=0.04)
        assets, trades = backtester.run_backtest()
        
        print(f"初始投入总资产: 100000.00 元")
        print(f"最终测算总资产: {assets['total_asset'].iloc[-1]:.2f} 元")
        print(f"共计触发网格交易次数: {len(trades)} 次")
        
        # 渲染图表
        plot_grid_results(df_test, assets, trades)
